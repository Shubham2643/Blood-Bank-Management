# Database
MONGO_URI=mongodb://127.0.0.1:27017/blood-bank-management

# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVE_FRONTEND=false
FRONTEND_DIST=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
# Optional: save service account JSON as backend/firebase-service-account.json
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Admin seed (required for npm run seed:admin)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMeToAStrongPassword1
ADMIN_NAME=System Admin

# Email (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=BloodConnect <noreply@yourdomain.com>
